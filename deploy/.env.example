# ══════════════════════════════════════════════════════════════════════════════
# SX Fund API Server — Environment Variables
# Copy to: /var/www/sx-fund/.env.production
# Load with: pm2 start ecosystem.config.cjs --env production --env-file .env.production
#
# ⚠️  NEVER commit the real .env.production file — only this template.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: keep Replit DB (simplest — no migration needed)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Option B: GCP Cloud SQL (Postgres)
# DATABASE_URL=postgresql://sx_fund:PASSWORD@/sx_fund?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AABBCC...

# Production webhook URL — this switches bot from polling → webhook mode
# Format: https://api.trinityfund.io/api/bot/webhook
TELEGRAM_WEBHOOK_URL=https://api.trinityfund.io/api/bot/webhook

# Random secret (min 32 chars) — Telegram sends this in X-Telegram-Bot-Api-Secret-Token
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_openssl_rand_hex_32

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Sessions ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_64

# ── Admin ─────────────────────────────────────────────────────────────────────
# Protects POST /api/bot/setup-webhook endpoint
# Generate: openssl rand -hex 24
ADMIN_SECRET=REPLACE_WITH_openssl_rand_hex_24

# ── Domain ────────────────────────────────────────────────────────────────────
# Comma-separated — used by bot to build button URLs
REPLIT_DOMAINS=trinityfund.io
